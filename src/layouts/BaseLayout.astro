---
import { ClientRouter } from 'astro:transitions';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '../styles/global.css';
import { siteConfig } from '../config';

interface Props {
  title?: string;
  description?: string;
  showFooter?: boolean;
}

const baseTitle = siteConfig.title;
const {
  title = baseTitle,
  description = "A minimal personal website",
  showFooter = true,
} = Astro.props;

const suffix = `- ${baseTitle}`;
const documentTitle =
  title === baseTitle
    ? baseTitle
    : title.endsWith(suffix)
      ? title
      : `${title} ${suffix}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <ClientRouter />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    {siteConfig.googleSiteVerification && (
      <meta name="google-site-verification" content={siteConfig.googleSiteVerification} />
    )}
    <meta name="generator" content={Astro.generator} />
    <title>{documentTitle}</title>
  </head>
  <body class="bg-[#FDFDFC] text-[#1A1A1A] antialiased selection:bg-[#EAE6DF] min-h-screen px-6 py-8 sm:px-10 sm:py-10 md:px-14 md:py-14">
    <!-- <canvas class="terrazzo-canvas" aria-hidden="true" transition:persist></canvas> -->
    <div class="site-shell site-shell--centered relative z-10 flex flex-col">
      <div class="site-main relative flex-1 max-w-[640px] w-full">
        <!-- <div class="site-rule" aria-hidden="true"></div> -->
        <div class="site-content" transition:name="crossfade">
          <slot />
        </div>
        {showFooter && (
          <footer class="site-footer">
            &copy; 2026 {siteConfig.name} &middot; {siteConfig.location}
          </footer>
        )}
      </div>
    </div>
    <!--
    <script is:inline>
      (() => {
        if (window.__terrazzoBackgroundInitialized) return;
        window.__terrazzoBackgroundInitialized = true;

        const body = document.body;
        const canvas = document.querySelector('.terrazzo-canvas');
