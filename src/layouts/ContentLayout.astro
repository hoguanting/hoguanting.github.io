---
import BaseLayout from './BaseLayout.astro';
import AdModule from '../components/AdModule.astro';
import { formatIsoDate } from '../lib/date';

interface Props {
  title: string;
  date: Date;
}

const { title, date } = Astro.props;
---

<BaseLayout title={title}>
  <main class="flex-1 mt-4">
    <header class="mb-10 border-b border-[var(--color-border)] pb-8">
      <h1 class="type-entry-title mb-3">{title}</h1>
      <time class="type-meta">{formatIsoDate(date)}</time>
    </header>
    
    <article class="site-prose max-w-none">
      <slot />
    </article>

    <AdModule />
  </main>
</BaseLayout>
