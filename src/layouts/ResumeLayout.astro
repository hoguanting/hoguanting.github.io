---
import { siteConfig } from '../config';
import '../styles/global.css';

interface Props {
  title?: string;
  frontmatter?: {
    title?: string;
  };
}

const { title: rawTitle, frontmatter } = Astro.props;
const title = rawTitle ?? frontmatter?.title ?? `Resume - ${siteConfig.name}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      @media print {
        body {
          background: white;
          color: black;
        }

        .no-print {
          display: none !important;
        }
      }
    </style>
  </head>
  <body class="bg-[#FDFDFC] text-[#1A1A1A] antialiased min-h-screen">
    <div class="max-w-[700px] mx-auto px-6 py-12 md:py-16">
      <div class="mb-12 flex justify-between items-center no-print border-b border-[var(--color-border)] pb-6">
        <a href="/" class="type-link-row hover:text-[var(--color-brand)]">&larr; Back to Home</a>
        <button
          onclick="window.print()"
          class="type-link-row text-[var(--color-brand)] hover:opacity-80 cursor-pointer border-none bg-transparent"
        >
          Print to PDF
        </button>
      </div>

      <article class="resume-prose max-w-none">
        <slot />
      </article>
    </div>
  </body>
</html>
