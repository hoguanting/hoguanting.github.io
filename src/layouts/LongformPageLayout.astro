---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  intro?: string;
  frontmatter?: {
    title?: string;
    description?: string;
    intro?: string;
  };
}

const {
  title: rawTitle,
  description: rawDescription,
  intro: rawIntro,
  frontmatter,
} = Astro.props;

const title = rawTitle ?? frontmatter?.title ?? '';
const description = rawDescription ?? frontmatter?.description;
const intro = rawIntro ?? frontmatter?.intro;
---

<BaseLayout title={title} description={description}>
  <main class="flex-1 mt-4">
    <header class="mb-8">
      <h1 class="type-home-title mb-2">{title}</h1>
      {intro && <p class="type-subtitle max-w-[38rem]">{intro}</p>}
    </header>

    <article class="site-prose max-w-none space-y-0">
      <slot />
    </article>
  </main>
</BaseLayout>
