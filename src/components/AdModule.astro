---
import { siteConfig } from '../config';

const showAd = siteConfig.openToWork;
---

{showAd && (
  <div class="mt-16 pt-8 border-t border-[var(--color-border)] opacity-90">
    <div class="bg-[var(--color-border)]/10 p-6 rounded-md">
      <h3 class="text-xs font-medium uppercase tracking-wider text-[var(--color-brand)] mb-3">Available For Work</h3>
      <p class="text-sm text-[#2E2E2A] mb-4 leading-relaxed">
        Early-career engineer interested in product engineering and thoughtful teams. Based in Kuala Lumpur, open to remote.
      </p>
      <div class="flex gap-4 text-sm font-medium">
        <a href={siteConfig.links.email} class="text-[var(--color-brand)] hover:brightness-110">Email</a>
        <a href="/resume" class="text-[var(--color-brand)] hover:brightness-110">Resume</a>
      </div>
    </div>
  </div>
)}
