---
import type { RecommendationItem, RecommendationCategory } from '../data/recommendations';
import RecommendationIcon from './RecommendationIcon.astro';

interface Props {
  title: string;
  category: RecommendationCategory;
  items: RecommendationItem[];
}

const { title, category, items } = Astro.props;
---

<section>
  <h2 class="type-section-title mb-3">{title}</h2>
  <ul class="space-y-1">
    {items.map((item) => (
      <li class="group py-0.5 list-none">
        {item.url ? (
          <div class="flex items-start justify-between gap-2">
            <div class="flex items-start gap-2.5 w-full">
              <RecommendationIcon category={category} />
              <div class="flex-1 min-w-0">
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="type-recommendation-title pt-[1px] no-underline hover:text-[var(--color-brand)] transition-colors"
                >
                  {item.title}
                </a>
              </div>
            </div>
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Open source for ${item.title}`}
              class="text-[var(--color-subtle)] hover:text-[var(--color-brand)] flex-shrink-0 transition-colors mt-[1px]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
            </a>
          </div>
        ) : (
          <div class="flex items-start gap-2.5 w-full">
            <RecommendationIcon category={category} />
            <div class="type-recommendation-title pt-[1px]">{item.title}</div>
          </div>
        )}
      </li>
    ))}
  </ul>
</section>
