---
import { getCollection, render } from 'astro:content';
import { getEntrySlug } from '../../lib/content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import ParkedSection from '../../components/ParkedSection.astro';
import { siteConfig } from '../../config';

export async function getStaticPaths() {
  const thoughtEntries = await getCollection('thoughts');
  return thoughtEntries.map(entry => ({
    params: { slug: getEntrySlug(entry) }, props: { entry },
  }));
}

const { entry } = Astro.props;
const rendered = siteConfig.sections.thoughts ? await render(entry) : undefined;
const Content = rendered?.Content;
---

{siteConfig.sections.thoughts && Content ? (
  <ContentLayout title={entry.data.title} date={entry.data.date}>
    <Content />
  </ContentLayout>
) : (
  <ParkedSection title="Thoughts" />
)}
