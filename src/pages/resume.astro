---
import { siteConfig } from '../config';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Resume - {siteConfig.name}</title>
  <meta name="viewport" content="width=device-width" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    @media print {
      body {
        background: white;
        color: black;
      }
      .no-print {
        display: none !important;
      }
    }
  </style>
</head>
<body class="bg-[#FDFDFC] text-[#1A1A1A] antialiased min-h-screen">
  <div class="max-w-[700px] mx-auto px-6 py-12 md:py-16">
    <div class="mb-12 flex justify-between items-center no-print border-b border-[var(--color-border)] pb-6">
      <a href="/" class="text-sm font-medium hover:text-[var(--color-brand)]">&larr; Back to Home</a>
      <button onclick="window.print()" class="text-sm font-medium text-[var(--color-brand)] hover:opacity-80 cursor-pointer border-none bg-transparent">Print to PDF</button>
    </div>

    <!-- Resume Content -->
    <header class="mb-10">
      <h1 class="text-3xl font-medium tracking-tight mb-2">{siteConfig.name}</h1>
      <div class="text-[var(--color-subtle)] text-sm flex gap-4">
        <a href={siteConfig.links.email} class="hover:underline">{siteConfig.links.email.replace('mailto:', '')}</a>
        <a href={siteConfig.links.github} class="hover:underline">GitHub</a>
        <span>Based in Kuala Lumpur</span>
      </div>
    </header>

    <section class="mb-8">
      <h2 class="text-sm font-medium uppercase tracking-wider text-[var(--color-subtle)] mb-4 border-b border-[var(--color-border)] pb-2">Experience</h2>
      <div class="space-y-6">
        <div>
          <div class="flex justify-between items-baseline mb-1">
            <h3 class="font-medium">Software Engineer</h3>
            <span class="text-sm text-[var(--color-subtle)] tabular-nums">2024 &mdash; Present</span>
          </div>
          <p class="text-sm mb-2 text-[#2E2E2A]">Acme Corp</p>
          <ul class="text-sm text-[#2E2E2A] list-disc pl-4 space-y-1">
            <li>Developed core infrastructure using modern web technologies.</li>
            <li>Collaborated with design team to enforce unified UI components.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-sm font-medium uppercase tracking-wider text-[var(--color-subtle)] mb-4 border-b border-[var(--color-border)] pb-2">Education</h2>
      <div>
        <div class="flex justify-between items-baseline mb-1">
          <h3 class="font-medium">B.S. Computer Science</h3>
          <span class="text-sm text-[var(--color-subtle)] tabular-nums">2023</span>
        </div>
        <p class="text-sm text-[#2E2E2A]">University Example</p>
      </div>
    </section>
  </div>
</body>
</html>
