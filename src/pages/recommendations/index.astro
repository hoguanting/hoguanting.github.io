---
import LongformPageLayout from '../../layouts/LongformPageLayout.astro';
import RecommendationSection from '../../components/RecommendationSection.astro';
import { recommendationSections } from '../../data/recommendations';
---

<LongformPageLayout
  title="Recommendations"
  intro="Things I would point people to, revisit, or keep returning to."
>
  <div class="space-y-8 not-prose">
    {recommendationSections.map((section) => (
      <RecommendationSection
        title={section.title}
        category={section.category}
        items={section.items}
      />
    ))}
  </div>
</LongformPageLayout>
