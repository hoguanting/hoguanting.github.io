---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config";
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <main class="flex-1 mt-4">
    <h1 class="text-3xl font-medium tracking-tight text-[#111111] mb-2">
      {siteConfig.name}
    </h1>
    <p class="page-subtitle">
      {siteConfig.shortBio}
    </p>

    <div class="max-w-none space-y-4 text-[#2E2E2A]">
      <p>
        I'm a software engineer focused on building fast, reliable, and
        user-centric applications. Previously, I studied computer science at <a
          href="https://www.monash.edu/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[var(--color-brand)]"
          >Monash University</a
        > and spent time exploring how tools shape the way we think.
      </p>
      <p>
        Currently, I'm interested in the intersection of design engineering,
        compiler infrastructure, and local-first software. I believe that the
        best software feels calm and transparent to its users.
      </p>
      <p>
        Outside of work, you can find me exploring the coffee shops around Kuala
        Lumpur, reading science fiction, or learning about urban design.
      </p>
    </div>

    <!-- Optional links inline if required -->
    <div class="mt-8 pt-6">
      <div class="flex gap-4 text-sm font-medium">
        <a
          href={siteConfig.links.github}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[var(--color-brand)]">GitHub</a
        >
        <a
          href={siteConfig.links.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[var(--color-brand)]">LinkedIn</a
        >
        <a href={siteConfig.links.email} class="hover:text-[var(--color-brand)]"
          >Email</a
        >
        <a href="/resume" class="hover:text-[var(--color-brand)]">Resume</a>
      </div>
    </div>
  </main>
</BaseLayout>
